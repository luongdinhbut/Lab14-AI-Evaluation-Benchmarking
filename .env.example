# Copy this file to .env and fill in your own key.
# Never commit .env.

GEMINI_API_KEY=your_gemini_api_key_here

# Two different Gemini judge models for Multi-Judge consensus.
GEMINI_JUDGE_MODEL_A=gemini-2.5-flash-lite
GEMINI_JUDGE_MODEL_B=gemini-3.1-flash-lite

# Judge settings.
GEMINI_JUDGE_TEMPERATURE=0
GEMINI_JUDGE_CONFLICT_THRESHOLD=1.0
GEMINI_JUDGE_MAX_CONCURRENCY=2

# Keep this true for classroom/demo runs without an API key.
# Set to false when you want the benchmark to fail if Gemini cannot be called.
GEMINI_ALLOW_MOCK_FALLBACK=true

# Optional pricing inputs for cost estimates. Set these to current Gemini pricing.
GEMINI_INPUT_COST_PER_1M=0
GEMINI_OUTPUT_COST_PER_1M=0
